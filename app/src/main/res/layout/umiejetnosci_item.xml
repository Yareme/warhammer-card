<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/karta_item_backgroundd">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingBottom="8dp">

            <!-- Nazwa -->
            <TextView
                android:id="@+id/nazwa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="8.9"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:ellipsize="end"
                android:singleLine="false"
                android:breakStrategy="simple"
                android:lineSpacingExtra="2dp"
                android:gravity="start"
                tools:text="Broń Zasięgowa(Broń ęksperementalna)" />

            <!-- Cecha -->
            <TextView
                android:id="@+id/cecha"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="17sp"
                android:textStyle="bold"
                android:gravity="end"
                android:ellipsize="end"
                android:singleLine="true"
                tools:text="(ZR)" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <TextView
                android:id="@+id/wartoscZcehy"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:gravity="center"
                tools:text="55" />

            <!-- Przycisk "-" -->
            <ImageButton
                android:id="@+id/buttonMinus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_minus_one"
                android:tint="@color/white"
                android:contentDescription="Zmniejsz wartość" />

            <!-- Pole liczby -->
            <EditText
                android:id="@+id/ilosc"
                android:layout_width="60dp"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:inputType="number"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="@android:color/transparent"
                tools:text="15" />

            <!-- Przycisk "+" -->
            <ImageButton
                android:id="@+id/buttonPlus"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?android:attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:src="@drawable/ic_plus_one"
                android:tint="@color/white"
                android:contentDescription="Zwiększ wartość" />

            <TextView
                android:id="@+id/summa"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                tools:text="75" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
