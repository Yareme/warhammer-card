<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/karta_item_backgroundd">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">


    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:background="?android:attr/selectableItemBackground"
            android:layout_marginBottom="8dp">

            <!-- Kolumna z informacjami o pancerzu -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:paddingEnd="8dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <!-- Nazwa pancerza -->
                    <TextView
                        android:id="@+id/nazwa"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textStyle="bold"
                        android:textSize="@dimen/titel_list_item"
                        tools:text="Metalowy Hełm" />

                    <!-- Dostępność -->
                    <TextView
                        android:id="@+id/dostepnosc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="@dimen/titel_ex_list_item"
                        android:paddingStart="8dp"
                        android:textColor="#FFFFFF"
                        tools:text="Rzadki" />
                </LinearLayout>

                <!-- Lokalizacja -->
                <TextView
                    android:id="@+id/lokalizacja"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/elemet_item_list"
                    tools:text="Głowa, Nogi, Ramiona" />

                <!-- Punkty pancerza -->
                <TextView
                    android:id="@+id/pp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/elemet_item_list"
                    tools:text="2 PP" />

                <!-- Cechy -->
                <TextView
                    android:id="@+id/cechy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/elemet_item_list"
                    tools:text="Giętki, Słaby Punkt" />

                <CheckBox
                    android:id="@+id/czy_zalozony"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Czy założony?" />
            </LinearLayout>

            <ImageView
                android:id="@+id/info"
                android:layout_width="@dimen/help_img"
                android:layout_height="@dimen/help_img"
                android:src="@android:drawable/ic_menu_help"
                android:contentDescription="Info"
                android:layout_gravity="center_vertical"
                android:paddingStart="8dp"
                android:clickable="true"
                android:focusable="true" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>