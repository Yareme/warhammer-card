<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    tools:context=".ui.karta.KartaTalenty.KartaTalentFragment"
    >

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        tools:listitem="@layout/talent_item" />


    <com.github.clans.fab.FloatingActionMenu
        android:id="@+id/fab_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:menu_labels_position="left"
        app:menu_openDirection="up"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/wszystkei_talenty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fab_label="Wszystkie Talenty"
            app:fab_size="mini"
            app:fab_colorNormal="@color/teal_700"
            app:fab_colorPressed="@color/teal_200"/>

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/talenty_profesji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fab_label="Telenty Profesji"
            app:fab_size="mini"
            app:fab_colorNormal="@color/teal_700"
            app:fab_colorPressed="@color/teal_200"/>

    </com.github.clans.fab.FloatingActionMenu>

</androidx.constraintlayout.widget.ConstraintLayout>