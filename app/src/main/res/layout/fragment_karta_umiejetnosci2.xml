    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/list"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        tools:listitem="@layout/umiejetnosci_item" />

    <com.github.clans.fab.FloatingActionMenu
        android:id="@+id/fab_menu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:menu_labels_position="left"
        app:menu_openDirection="up"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        >

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/wszystkie_zaawansowane"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fab_label="Wszystkie Umiejętności"
            app:fab_size="mini"
            app:fab_colorNormal="@color/teal_700"
            app:fab_colorPressed="@color/teal_200"/>

        <com.github.clans.fab.FloatingActionButton
            android:id="@+id/zaawansowane_profesji"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:fab_label="Umiejętności Profesji"
            app:fab_size="mini"
            app:fab_colorNormal="@color/teal_700"
            app:fab_colorPressed="@color/teal_200"/>

    </com.github.clans.fab.FloatingActionMenu>

</androidx.constraintlayout.widget.ConstraintLayout>
