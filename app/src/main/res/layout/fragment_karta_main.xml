<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fragment_karta_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.karta.KartaMainFragment"
    android:theme="@style/Theme.MyApp"
    android:background="@drawable/tlo"
    >

    <!-- Tło obrazu -->
    <ImageView
        android:id="@+id/backgroundImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/tlo"
        android:scaleType="centerCrop" />

    <!-- Nakładka półprzezroczysta -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#33FFFFFF" />

    <Button
        android:id="@+id/button1"
        android:layout_width="390dp"
        android:layout_height="69dp"
        android:text="Profil"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.0"
        style="@style/CustomButtonStyle"
        />

    <Button
        android:id="@+id/button7"
        android:layout_width="177dp"
        android:layout_height="79dp"
        android:layout_marginStart="5dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="16dp"
        android:text="Punkty"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.977"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button1"
        style="@style/CustomButtonStyle"
        />

    <Button
        android:id="@+id/button2"
        android:layout_width="177dp"
        android:layout_height="79dp"
        android:layout_marginStart="16dp"
        android:layout_marginTop="15dp"
        android:layout_marginEnd="5dp"
        android:text="Cechy"
        app:layout_constraintEnd_toStartOf="@+id/button7"
        app:layout_constraintHorizontal_bias="0.28"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button1"
        style="@style/CustomButtonStyle"
        />

    <Button
        android:id="@+id/button3"
        android:layout_width="164dp"
        android:layout_height="273dp"
        android:layout_marginStart="28dp"
        android:layout_marginBottom="272dp"
        android:text="Umijętności"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button2"
        app:layout_constraintVertical_bias="1.0"
        style="@style/CustomButtonStyle"
        />

    <Button
        android:id="@+id/button4"
        android:layout_width="164dp"
        android:layout_height="273dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="272dp"
        android:text="Umijętności Zaowansowane"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/CustomButtonStyle"
        />

    <Button
        android:id="@+id/button5"
        android:layout_width="155dp"
        android:layout_height="253dp"
        android:layout_marginBottom="4dp"
        android:text="Talenty"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.113"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button3"
        app:layout_constraintVertical_bias="1.0"
        style="@style/CustomButtonStyle"
        />

    <Button
        android:id="@+id/button8"
        android:layout_width="185dp"
        android:layout_height="108dp"
        android:layout_marginTop="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="20dp"
        android:text="Ambicja"
        app:layout_constraintBottom_toTopOf="@+id/button6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/button4"
        style="@style/CustomButtonStyle"
        />

    <Button
        android:id="@+id/button6"
        android:layout_width="185dp"
        android:layout_height="108dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="4dp"
        android:text="Drużyna"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        style="@style/CustomButtonStyle"
        />


</androidx.constraintlayout.widget.ConstraintLayout>

