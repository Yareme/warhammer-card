<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    tools:context=".ui.karta.KartaPunkty.KartaPunktyFragment"
    android:id="@+id/fragment_karta_punkty"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >


    <!--
    android:weightSum="3"



    android:layout_weight="3"
    android:hint="3/8"

     -->

    <LinearLayout
        android:id="@+id/doswiadczenie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/doswiadczenie"
            android:textSize="@dimen/punkty_titel"
            android:textStyle="bold"
            android:gravity="center" />

        <ImageView
            android:id="@+id/help_doswiadczenie"
            android:layout_width="@dimen/help_img"
            android:layout_height="@dimen/help_img"
            android:contentDescription="Pomoc"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_help" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/blok_exp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="1dp"
        app:layout_constraintTop_toBottomOf="@id/doswiadczenie"
        >
    <LinearLayout
        android:id="@+id/text_exp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:padding="5dp"
        >

        <TextView
            android:id="@+id/aktualne_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="@dimen/punkty_subtitle"
            android:textStyle="bold"
            android:labelFor="@id/aktualne"
            android:text="@string/aktualny"
            />

        <TextView
            android:id="@+id/wydane_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textSize="@dimen/punkty_subtitle"
            android:textStyle="bold"
            android:text="@string/wydany"
            />
        <TextView
            android:id="@+id/suma_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="@dimen/punkty_subtitle"
            android:textStyle="bold"
            android:gravity="center"
            android:text="@string/suma"
            />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/edit_exp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="3"
        android:padding="5dp"
        app:layout_constraintTop_toBottomOf="@id/text_exp"
        >

        <EditText
            android:id="@+id/aktualne"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:importantForAutofill="no"
            android:inputType="number"
            android:textSize="@dimen/punkty_value"
            android:textStyle="bold"
            tools:text="1500"

            />

        <EditText
            android:id="@+id/wydane"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:importantForAutofill="no"
            android:inputType="number"
            android:textSize="@dimen/punkty_value"
            android:textStyle="bold"
            tools:text="456 (750)" />

        <EditText
        android:id="@+id/suma"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:textSize="@dimen/punkty_value"
        android:textStyle="bold"
        android:gravity="center"
        tools:text="1956"
        android:focusable="false"
        android:clickable="false"
        android:inputType="number"
        android:importantForAutofill="no"
        android:maxWidth="488dp"

        />
    </LinearLayout>

    </LinearLayout>


    <LinearLayout
        android:id="@+id/bohater"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/blok_exp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/bohater"
        android:textSize="@dimen/punkty_titel"
        android:textStyle="bold"
        android:gravity="center"
        />

    <ImageView
        android:id="@+id/help_bohater"
        android:layout_width="@dimen/help_img"
        android:layout_height="@dimen/help_img"
        android:src="@android:drawable/ic_menu_help"
        android:contentDescription="Pomoc"
        android:padding="4dp"/>
</LinearLayout>

    <LinearLayout
        android:id="@+id/blok_bohatera"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="1dp"
        app:layout_constraintTop_toBottomOf="@id/bohater"
        >
        <LinearLayout
            android:id="@+id/text_punk_bohatera"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:padding="5dp"
            >

            <TextView
                android:id="@+id/bohater_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_subtitle"
                android:textStyle="bold"
                android:gravity="center"
                android:text="@string/bohater"
                />

            <TextView
                android:id="@+id/determinacja_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_subtitle"
                android:textStyle="bold"
                android:gravity="center"
                android:text="@string/determinacja"
                />
            <TextView
                android:id="@+id/dodatkowy_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_subtitle"
                android:textStyle="bold"
                android:gravity="center"
                android:text="@string/dodatkowe"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/edit_bohater"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:padding="5dp"
            app:layout_constraintTop_toBottomOf="@id/text_exp"
            >

            <EditText
                android:id="@+id/bohater_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_value"
                android:textStyle="bold"
                android:gravity="center"
                tools:text="1"
                android:inputType="number"
                android:importantForAutofill="no"

                />

            <EditText
                android:id="@+id/determinacja_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_value"
                android:textStyle="bold"
                android:gravity="center"
                tools:text="0"
                android:inputType="number"
                android:importantForAutofill="no"

                />
            <EditText
                android:id="@+id/dodatkowe_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_value"
                android:textStyle="bold"
                android:gravity="center"
                tools:text="5"
                android:inputType="number"
                android:importantForAutofill="no"

                />
        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/przeznaczenie"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/blok_bohatera"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/przeznaczenie"
        android:textSize="@dimen/punkty_titel"
        android:textStyle="bold"
        android:gravity="center"

        />

        <ImageView
            android:id="@+id/help_przeznaczenie"
            android:layout_width="@dimen/help_img"
            android:layout_height="@dimen/help_img"
            android:src="@android:drawable/ic_menu_help"
            android:contentDescription="Pomoc"
            android:padding="4dp"/>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/blok_przeznaczenia"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="1dp"
        app:layout_constraintTop_toBottomOf="@id/przeznaczenie"
        >
        <LinearLayout
            android:id="@+id/text_punk_przeznaczenia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:padding="5dp"
            >

            <TextView
                android:id="@+id/przeznaczenia_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_subtitle"
                android:textStyle="bold"
                android:gravity="center"
                android:text="Przeznaczenia"
                />

            <TextView
                android:id="@+id/szczescia_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_subtitle"
                android:textStyle="bold"
                android:gravity="center"
                android:text="@string/szcz_cia"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/edit_przeznaczenia"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            android:padding="5dp"
            app:layout_constraintTop_toBottomOf="@id/text_exp"
            >


            <EditText
                android:id="@+id/przeznaczenia_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:textSize="@dimen/punkty_value"
                android:textStyle="bold"
                tools:text="2"
                android:inputType="number"
                android:importantForAutofill="no"
                app:layout_constraintWidth_max="488dp"
                />

            <EditText
                android:id="@+id/szcze_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:gravity="center"
                android:importantForAutofill="no"
                android:inputType="number"
                android:textSize="@dimen/punkty_value"
                android:textStyle="bold"
                app:layout_constraintWidth_max="488dp"
                tools:text="3"

                />
        </LinearLayout>

    </LinearLayout>
    <LinearLayout
        android:id="@+id/szybkosc"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/blok_przeznaczenia"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/szybko"
        android:textSize="@dimen/punkty_titel"
        android:textStyle="bold"
        android:gravity="center"
        />

        <ImageView
            android:id="@+id/help_szybkosc"
            android:layout_width="@dimen/help_img"
            android:layout_height="@dimen/help_img"
            android:src="@android:drawable/ic_menu_help"
            android:contentDescription="Pomoc"
            android:padding="4dp"/>
    </LinearLayout>


    <LinearLayout
        android:id="@+id/blok_szybkosc"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="1dp"
        app:layout_constraintTop_toBottomOf="@id/szybkosc"
        >
        <LinearLayout
            android:id="@+id/text_szybkosc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:padding="5dp"
            >

            <TextView
                android:id="@+id/szybkosc_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_subtitle"
                android:textStyle="bold"
                android:gravity="center"
                android:text="@string/szybko"
                />

            <TextView
                android:id="@+id/chod_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_subtitle"
                android:textStyle="bold"
                android:gravity="center"
                android:text="@string/ch_d"
                />
            <TextView
                android:id="@+id/bieg_text"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_subtitle"
                android:textStyle="bold"
                android:gravity="center"
                android:text="@string/bieg"
                />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/edit_szybkosc"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="3"
            android:padding="5dp"
            app:layout_constraintTop_toBottomOf="@id/text_exp"
            >

            <EditText
                android:id="@+id/szybkosc_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_value"
                android:textStyle="bold"
                android:gravity="center"
                tools:text="4"
                android:inputType="number"
                android:importantForAutofill="no"

                />

            <EditText
                android:id="@+id/chod_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:clickable="false"
                android:focusable="false"
                android:gravity="center"
                android:inputType="number"
                android:textSize="@dimen/punkty_value"
                android:textStyle="bold"
                tools:text="8"
                android:importantForAutofill="no"
                app:layout_constraintWidth_percent="0.3"

                />

            <EditText
                android:id="@+id/bieg_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_value"
                android:textStyle="bold"
                android:gravity="center"
                tools:text="16"
                android:focusable="false"
                android:clickable="false"
                android:inputType="number"
                android:importantForAutofill="no"

                />
        </LinearLayout>

    </LinearLayout>


    <LinearLayout
        android:id="@+id/motywacja"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/blok_szybkosc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/motywacja"
        android:textSize="@dimen/punkty_titel"
        android:textStyle="bold"
        android:gravity="center"
        />

        <ImageView
            android:id="@+id/help_motywacja"
            android:layout_width="@dimen/help_img"
            android:layout_height="@dimen/help_img"
            android:src="@android:drawable/ic_menu_help"
            android:contentDescription="@string/pomoc"
            android:padding="4dp"/>
    </LinearLayout>



    <EditText
                android:id="@+id/motywacja_edit"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="@dimen/punkty_subtitle"
                android:textStyle="bold"
                android:gravity="center"
                android:hint="@string/kr_tka_motywacja_postaci"
                android:inputType="text"
                android:importantForAutofill="no"
                app:layout_constraintTop_toBottomOf="@id/motywacja"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                />


</androidx.constraintlayout.widget.ConstraintLayout>
