<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp"
    app:cardBackgroundColor="@color/karta_item_backgroundd">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">


        <!-- Nazwa talentu -->


        <!-- Maksimum + ikona pomocy -->
        <LinearLayout
            android:id="@+id/talent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="start"
            android:orientation="horizontal"
            android:weightSum="1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <TextView
                android:id="@+id/talent_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="start"
                android:textColor="@color/black"
                android:textSize="22sp"
                android:textStyle="bold"
                tools:text="Berserkerska Szarża" />

            <ImageButton
                android:id="@+id/buttonMinus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackground"
                android:contentDescription="Zmniejsz ilość"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_minus_one" />

            <!-- Pole z liczbą -->
            <EditText
                android:id="@+id/lvl"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:background="@android:color/transparent"
                android:gravity="center"

                android:importantForAutofill="no"
                android:inputType="number"
                android:focusable="false"
                android:clickable="false"

                android:textSize="25sp"
                android:textStyle="bold"
                tools:text="1" />

            <!-- Przycisk "+" -->
            <ImageButton
                android:id="@+id/buttonPlus"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:background="?android:attr/selectableItemBackground"
                android:contentDescription="Zwiększ ilość"
                android:padding="8dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_plus_one" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/maksimum_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/talent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/maksimum"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="18sp"
                tools:text="Maksimum: Bonus z Siły" />

            <ImageView
                android:id="@+id/help_icon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="8dp"
                android:src="@android:drawable/ic_menu_help"
                android:contentDescription="Pomoc"
                android:clickable="true"
                android:focusable="true"
                app:tint="@color/gray" />
        </LinearLayout>

        <!-- Testy -->
        <TextView
            android:id="@+id/testy"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textColor="@color/black"
            android:textSize="18sp"
            tools:text="Testy: Broń Biała w Rundzie, w której Szarżowałeś"
            app:layout_constraintTop_toBottomOf="@id/maksimum_container"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Opis + przycisk Pokaż więcej -->
        <LinearLayout
            android:id="@+id/opis_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/testy"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/opis"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/black"
                android:textSize="16sp"
                android:ellipsize="end"
                tools:text="Nie licząc się z niebezpieczeństwem, rzucasz się na przeciwników, by pędem i siłą zadawać mocniejsze ciosy. Kiedy Szarżujesz, zadajesz +1 punkt obrażeń we wszystkich atakach Walki Wręcz za każde wykupienie tego Talentu." />

        <!--    <Button
                android:id="@+id/pokaz_wiecej"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Pokaż więcej"
                android:textSize="14sp"
                android:layout_gravity="end"
                android:background="?attr/selectableItemBackground"
                android:padding="4dp"/>-->

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
