<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Warhammer_Card" parent="Theme.AppCompat.Light">
        <!-- Primary brand color. -->
        <item name="colorPrimary">#9A6A4611</item>
        <item name="colorPrimaryVariant">#9A6A4611</item>
        <item name="colorOnPrimary">#E66E778B</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <item name="buttonStyle">@style/Widget.AppCompat.Button</item>
        <item name="android:buttonStyle">@null</item>

        <!-- Customize your theme here. -->
    </style>

    <style name="Theme.Warhammer_Card.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.Warhammer_Card.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <style name="Theme.Warhammer_Card.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />
</resources>